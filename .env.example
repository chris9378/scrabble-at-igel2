# Environment Variables Template

# ============================================================================
# GENERAL
# ============================================================================
NODE_ENV=development
APP_NAME=scrabble-at-igel
LOG_LEVEL=info

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=scrabble
DB_TIMEZONE=UTC

# ============================================================================
# CACHE (Redis)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# BACKEND SERVER
# ============================================================================
BACKEND_HOST=localhost
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000

# ============================================================================
# FRONTEND
# ============================================================================
FRONTEND_HOST=localhost
FRONTEND_PORT=4200
FRONTEND_URL=http://localhost:4200

# ============================================================================
# CORS & SECURITY
# ============================================================================
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=true

# ============================================================================
# SOCKET.IO
# ============================================================================
SOCKET_IO_CORS_ORIGIN=http://localhost:4200
SOCKET_IO_PING_INTERVAL=25000
SOCKET_IO_PING_TIMEOUT=60000

# ============================================================================
# GAME SETTINGS
# ============================================================================
MAX_PLAYERS_PER_GAME=3
MIN_PLAYERS_TO_START=2
GAME_SESSION_TIMEOUT=3600000
AI_DIFFICULTY_EASY_DELAY_MS=1000
AI_DIFFICULTY_MEDIUM_DELAY_MS=2000
AI_DIFFICULTY_HARD_DELAY_MS=3000

# ============================================================================
# DICTIONARY SETTINGS
# ============================================================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,de

# ============================================================================
# JWT (für zukünftige Authentifizierung)
# ============================================================================
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# ============================================================================
# LOGGING
# ============================================================================
LOG_FORMAT=json
SENTRY_DSN=

